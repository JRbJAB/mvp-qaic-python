{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "qaic.public.prompt_template.schema.v1",
  "title": "QAIC Public Prompt Template",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompt_id", "prompt_name", "prompt_category", "input_required", "output_expected", "safety_blocks", "human_review_only", "public_safe", "version", "last_updated"],
  "properties": {
    "prompt_id": {"type": "string", "minLength": 1},
    "prompt_name": {"type": "string", "minLength": 1},
    "prompt_category": {"type": "string", "minLength": 1},
    "input_required": {"type": "string", "minLength": 1},
    "output_expected": {"type": "string", "minLength": 1},
    "safety_blocks": {"type": "string", "minLength": 1},
    "human_review_only": {"type": "boolean", "const": true},
    "public_safe": {"type": "boolean", "const": true},
    "version": {"type": "string", "minLength": 1},
    "last_updated": {"type": "string"}
  }
}